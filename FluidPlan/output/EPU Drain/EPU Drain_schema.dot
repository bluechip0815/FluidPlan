digraph PneumaticSchema {
    rankdir=LR; // Layout from Left to Right
    node [shape=box, fixedsize=true, width=1, height=1, labelloc=b];
    Supply [label="Supply", image="D:\repos\FluidPlan\FluidPlan\schema_icons\supply.png", labelloc=b];
    EPU [label="EPU", image="D:\repos\FluidPlan\FluidPlan\schema_icons\epu.png", labelloc=b];
    R1 [label="R1", image="D:\repos\FluidPlan\FluidPlan\schema_icons\pipe.png", labelloc=b];
    R2 [label="R2", image="D:\repos\FluidPlan\FluidPlan\schema_icons\pipe.png", labelloc=b];
    R3 [label="R3", image="D:\repos\FluidPlan\FluidPlan\schema_icons\pipe.png", labelloc=b];
    V1 [label="V1", image="D:\repos\FluidPlan\FluidPlan\schema_icons\valve.png", labelloc=b];
    V2 [label="V2", image="D:\repos\FluidPlan\FluidPlan\schema_icons\valve.png", labelloc=b];
    T1 [label="T1", image="D:\repos\FluidPlan\FluidPlan\schema_icons\tank.png", labelloc=b];
    Supply -> R1;
    R1 -> V1;
    V1 -> R2;
    R1 -> EPU;
